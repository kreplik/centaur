<% content_for :title, "Sign In · Iron Control" %>

<% input = "w-full rounded border border-ink-600 bg-ink-850/60 px-3 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:border-iron-500/60 focus:outline-none focus:ring-1 focus:ring-iron-500/40" %>
<% label = "mb-1 block text-xs font-semibold uppercase tracking-wider text-zinc-500" %>

<div class="mb-8 text-center">
  <h1 class="page-title">iron-<span class="text-iron-500">control</span></h1>
  <p class="page-subtitle">Operator console sign in.</p>
</div>

<% if flash[:notice] %>
  <div class="mb-6 rounded border border-ink-600 bg-ink-850/60 px-4 py-3 text-sm text-zinc-400"><%= flash[:notice] %></div>
<% end %>

<div class="rounded-xl border border-ink-600 bg-ink-850/60 p-6">
  <% if flash[:alert] %>
    <div class="alert-error"><%= flash[:alert] %></div>
  <% end %>

  <% providers = ConsoleAuth.providers %>
  <% if providers.any? %>
    <div class="space-y-3">
      <% providers.each do |provider| %>
        <%= link_to auth_start_path(provider: provider),
              class: "flex w-full items-center justify-center rounded border border-ink-600 bg-ink-800/60 px-4 py-2 text-sm text-zinc-200 transition-colors hover:border-iron-500/40 hover:text-iron-200" do %>
          Continue with <%= provider.capitalize %>
        <% end %>
      <% end %>
    </div>

    <div class="my-6 flex items-center gap-3 text-xs uppercase tracking-wider text-zinc-600">
      <span class="h-px flex-1 bg-ink-600"></span>
      or sign in with email
      <span class="h-px flex-1 bg-ink-600"></span>
    </div>
  <% end %>

  <%= form_with url: login_path, method: :post do |f| %>
    <div class="space-y-5">
      <div>
        <%= f.label :email, class: label %>
        <%= f.email_field :email, class: input, placeholder: "you@example.com", autocomplete: "username", autofocus: true %>
      </div>
      <div>
        <%= f.label :password, class: label %>
        <%= f.password_field :password, class: input, autocomplete: "current-password" %>
      </div>
    </div>

    <div class="mt-6">
      <%= f.submit "Sign in", class: "w-full cursor-pointer rounded border border-iron-500/40 bg-iron-500/10 px-4 py-2 text-sm text-iron-300 transition-colors hover:bg-iron-500/20 hover:text-iron-200" %>
    </div>
  <% end %>
</div>
